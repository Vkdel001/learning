# Database
DATABASE_URL="postgresql://ai_tutor_user:ai_tutor_password@localhost:5432/ai_tutor_db"

# Redis
REDIS_URL="redis://localhost:6379"

# Brevo (Email/OTP)
BREVO_API_KEY="your-brevo-api-key-here"

# Google Gemini AI
GEMINI_API_KEY="your-gemini-api-key-here"

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY="your-elevenlabs-api-key-here"

# Backblaze B2 (Audio Storage)
B2_KEY_ID="your-b2-key-id-here"
B2_APPLICATION_KEY="your-b2-application-key-here"
B2_BUCKET_NAME="ai-tutor-audio"
B2_ENDPOINT="https://s3.us-west-000.backblazeb2.com"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Session Secret (generate a random string)
SESSION_SECRET="your-random-session-secret-here"
