// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users table - OTP authentication (no passwords)
model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  grade        Int
  isUnder18    Boolean  @default(true) @map("is_under_18")
  authProvider String   @default("otp") @map("auth_provider")
  googleId     String?  @unique @map("google_id")
  createdAt    DateTime @default(now()) @map("created_at")
  lastLogin    DateTime? @map("last_login")
  isAdmin      Boolean  @default(false) @map("is_admin")
  
  progress     Progress[]
  quizAttempts QuizAttempt[] @relation("UserQuizAttempts")
  chatConversations ChatConversation[]
  learningProfile LearningProfile?
  topicMastery TopicMastery[]
  
  @@index([email])
  @@index([googleId])
  @@map("users")
}

// Sessions table
model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// Curriculum nodes with materialized paths
model CurriculumNode {
  id        String   @id @default(uuid())
  name      String
  path      String   @unique
  level     Int
  parentId  String?  @map("parent_id")
  nodeType  String   @map("node_type")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  
  parent   CurriculumNode?  @relation("NodeHierarchy", fields: [parentId], references: [id])
  children CurriculumNode[] @relation("NodeHierarchy")
  lessons  Lesson[]
  quizzes  Quiz[]
  topicMastery TopicMastery[]
  
  @@index([path])
  @@index([parentId])
  @@index([level])
  @@map("curriculum_nodes")
}

// Prompt templates with versioning
model PromptTemplate {
  id           String   @id @default(uuid())
  name         String
  templateType String   @map("template_type")
  version      Int
  content      String   @db.Text
  subjectId    String?  @map("subject_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  
  lessons Lesson[]
  quizzes Quiz[]
  
  @@unique([name, version])
  @@index([templateType, version])
  @@index([subjectId])
  @@map("prompt_templates")
}

// Lessons table
model Lesson {
  id                String   @id @default(uuid())
  subtopicId        String   @map("subtopic_id")
  contentHash       String   @unique @map("content_hash")
  explanation       String   @db.Text
  examples          Json
  keyPoints         Json     @map("key_points")
  practiceQuestions Json     @map("practice_questions")
  promptVersion     Int      @map("prompt_version")
  aiProvider        String   @map("ai_provider")
  createdAt         DateTime @default(now()) @map("created_at")
  
  subtopic         CurriculumNode @relation(fields: [subtopicId], references: [id])
  promptTemplateId String?        @map("prompt_template_id")
  promptTemplate   PromptTemplate? @relation(fields: [promptTemplateId], references: [id])
  progress         Progress[]
  audioSegments    AudioSegment[]
  chatConversations ChatConversation[]
  
  @@index([subtopicId])
  @@index([contentHash])
  @@map("lessons")
}

// Quizzes table
model Quiz {
  id            String   @id @default(uuid())
  topicId       String   @map("topic_id")
  contentHash   String   @unique @map("content_hash")
  difficulty    String   @default("medium") // easy, medium, hard
  questions     Json
  promptVersion Int      @map("prompt_version")
  aiProvider    String   @map("ai_provider")
  createdAt     DateTime @default(now()) @map("created_at")
  
  topic            CurriculumNode  @relation(fields: [topicId], references: [id])
  promptTemplateId String?         @map("prompt_template_id")
  promptTemplate   PromptTemplate? @relation(fields: [promptTemplateId], references: [id])
  attempts         QuizAttempt[]
  
  @@index([topicId])
  @@index([contentHash])
  @@index([topicId, difficulty])
  @@map("quizzes")
}

// Audio segments table
model AudioSegment {
  id         String   @id @default(uuid())
  textHash   String   @unique @map("text_hash")
  text       String   @db.Text
  audioUrl   String   @map("audio_url")
  duration   Int
  provider   String
  storageKey String   @map("storage_key")
  usageCount Int      @default(0) @map("usage_count")
  createdAt  DateTime @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  
  lessonId String? @map("lesson_id")
  lesson   Lesson? @relation(fields: [lessonId], references: [id])
  
  @@index([textHash])
  @@index([usageCount])
  @@map("audio_segments")
}

// Progress table
model Progress {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  lessonId    String   @map("lesson_id")
  completedAt DateTime @default(now()) @map("completed_at")
  
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id])
  
  @@unique([userId, lessonId])
  @@index([userId])
  @@index([completedAt])
  @@map("progress")
}

// Quiz attempts table
model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  quizId      String   @map("quiz_id")
  answers     Json
  score       Decimal  @db.Decimal(5, 2)
  timeSpent   Int      @map("time_spent")
  completedAt DateTime @default(now()) @map("completed_at")
  
  user User @relation("UserQuizAttempts", fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id])
  
  @@index([userId])
  @@index([quizId])
  @@index([completedAt])
  @@map("quiz_attempts")
}

// API usage logs table
model ApiUsageLog {
  id            String   @id @default(uuid())
  userId        String?  @map("user_id")
  operation     String
  provider      String
  tokensUsed    Int?     @map("tokens_used")
  responseTime  Int?     @map("response_time")
  success       Boolean
  errorMessage  String?  @map("error_message") @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@index([userId])
  @@index([createdAt])
  @@index([operation])
  @@map("api_usage_logs")
}

// Chat conversations table
model ChatConversation {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  lessonId      String   @map("lesson_id")
  startedAt     DateTime @default(now()) @map("started_at")
  lastMessageAt DateTime @default(now()) @map("last_message_at")
  messageCount  Int      @default(0) @map("message_count")
  
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson        @relation(fields: [lessonId], references: [id])
  messages ChatMessage[]
  
  @@index([userId, startedAt])
  @@index([lessonId])
  @@map("chat_conversations")
}

// Chat messages table
model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String   // 'user' or 'assistant'
  content        String   @db.Text
  tokensUsed     Int?     @map("tokens_used")
  createdAt      DateTime @default(now()) @map("created_at")
  
  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

// Chat analytics table - tracks common questions
model ChatAnalytics {
  id           String   @id @default(uuid())
  lessonId     String   @map("lesson_id")
  questionText String   @db.Text @map("question_text")
  questionHash String   @map("question_hash") // SHA-256 hash for deduplication
  askCount     Int      @default(1) @map("ask_count")
  lastAskedAt  DateTime @default(now()) @map("last_asked_at")
  
  @@unique([lessonId, questionHash])
  @@index([lessonId, askCount])
  @@map("chat_analytics")
}

// Learning profile - overall student learning data
model LearningProfile {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  overallSkillLevel String   @default("beginner") @map("overall_skill_level") // beginner, intermediate, advanced
  learningPace      String   @default("normal") @map("learning_pace") // slow, normal, fast
  lastActiveTopicId String?  @map("last_active_topic_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("learning_profiles")
}

// Topic mastery - tracks progress per curriculum topic
model TopicMastery {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  curriculumNodeId String   @map("curriculum_node_id")
  masteryLevel     Int      @default(0) @map("mastery_level") // 0-100
  status           String   @default("not_started") @map("status") // not_started, in_progress, mastered, needs_review
  lastPracticed    DateTime? @map("last_practiced")
  practiceCount    Int      @default(0) @map("practice_count")
  averageScore     Decimal? @db.Decimal(5, 2) @map("average_score")
  recentScores     Json?    @map("recent_scores") // Array of last 5 scores
  timeSpent        Int      @default(0) @map("time_spent") // Total minutes spent
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  curriculumNode CurriculumNode @relation(fields: [curriculumNodeId], references: [id])
  
  @@unique([userId, curriculumNodeId])
  @@index([userId, status])
  @@index([curriculumNodeId])
  @@map("topic_mastery")
}
